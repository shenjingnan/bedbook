{
  "name": "bedbook",
  "version": "0.0.1",
  "description": "儿童故事 MCP 服务 - 提供故事列表和搜索功能",
  "repository": {
    "type": "git",
    "url": "https://github.com/shenjingnan/bedbook.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "main": "dist/index.js",
  "bin": {
    "bedbook": "./dist/index.js"
  },
  "scripts": {
    "dev": "ts-node --transpile-only src/index.ts",
    "dev:http": "MCP_TRANSPORT=http MCP_PORT=3000 ts-node --transpile-only src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http MCP_PORT=3000 node dist/index.js",
    "spellcheck": "cspell \"src/**/*.ts\" \"stories/**/*.md\" \"*.md\"",
    "spellcheck:fix": "cspell --fix \"src/**/*.ts\" \"stories/**/*.md\" \"*.md\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "release": "release-it",
    "release:beta": "release-it --preRelease=beta --ci",
    "release:dry": "release-it --dry-run --ci",
    "release:patch": "release-it patch --ci",
    "release:minor": "release-it minor --ci",
    "release:major": "release-it major --ci"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "bedbook",
    "stories",
    "children"
  ],
  "author": "shenjingnan <sjn.code@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10",
  "dependencies": {
    "@biomejs/biome": "^2.4.6",
    "bestmcp": "^0.1.5",
    "gray-matter": "^4.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "cspell": "^9.7.0",
    "release-it": "^19.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
